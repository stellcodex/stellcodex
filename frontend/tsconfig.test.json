{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": true
  },
  "include": [
    "src/tests/**/*.ts",
    "src/tests/**/*.tsx",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/lib/**/*.ts",
    "src/lib/**/*.tsx",
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/styles/**/*.css"
  ]
}
