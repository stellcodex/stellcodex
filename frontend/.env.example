NEXT_PUBLIC_API_URL=https://api.stellcodex.com
# Optional legacy alias if older modules still read NEXT_PUBLIC_API_BASE:
NEXT_PUBLIC_API_BASE=https://api.stellcodex.com
# Local demo: 1, Production: 0
STELLCODEX_ENABLE_MOCK_ADMIN=0
# PROD schema MUST be fixed: schema=stellcodex_prod
# Method A (query param schema): runtime pooled Neon
DATABASE_URL=postgresql://USER:PASSWORD@POOLED_HOST/neondb?sslmode=require&schema=stellcodex_prod&options=endpoint%3DNEON_ENDPOINT
# Method A (query param schema): migrate/deploy direct Neon
DIRECT_URL=postgresql://USER:PASSWORD@DIRECT_HOST/neondb?sslmode=require&schema=stellcodex_prod&options=endpoint%3DNEON_ENDPOINT
# Method B (search_path inside options) alternatives:
# DATABASE_URL=postgresql://USER:PASSWORD@POOLED_HOST/neondb?sslmode=require&options=endpoint%3DNEON_ENDPOINT%20-c%20search_path%3Dstellcodex_prod
# DIRECT_URL=postgresql://USER:PASSWORD@DIRECT_HOST/neondb?sslmode=require&options=endpoint%3DNEON_ENDPOINT%20-c%20search_path%3Dstellcodex_prod
