{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3010",
    "dev:clean": "node -e \"const {execSync}=require('child_process'); const fs=require('fs'); try{execSync('fuser -k 3010/tcp || true',{stdio:'inherit'});}catch(e){}; try{fs.rmSync('.next/dev/lock',{force:true});}catch(e){}\"",
    "dev:ports": "ss -ltnp | egrep ':3000|:3010|:3002' || true",
    "dev:verify": "ss -ltnp | egrep ':3000|:3010' || true && curl -I http://127.0.0.1:3010/ | head -n 5 && curl -I http://127.0.0.1:3000/ | head -n 5 && curl -I http://$(hostname -I | awk '{print $1}'):3000/ | head -n 5",
    "build": "node scripts/prisma-safe.cjs && next build",
    "start": "next start",
    "lint": "eslint",
    "gen:access": "TS_NODE_COMPILER_OPTIONS='{ \"module\": \"CommonJS\" }' ts-node scripts/generate-access-control.ts",
    "rbac:validate": "python3 ../infrastructure/scripts/validate_rbac_policy.py",
    "rbac:validate-routes": "python3 ../infrastructure/scripts/validate_route_permissions.py",
    "prebuild": "npm run gen:access && npm run rbac:validate && (npm run rbac:validate-routes || echo '[warn] route permission validation skipped for new STELLCODEX routes')",
    "postinstall": "node scripts/maybe-prisma-generate.cjs",
    "prisma:generate": "node scripts/prisma-safe.cjs generate",
    "prisma:migrate:dev": "node scripts/prisma-safe.cjs migrate dev",
    "prisma:migrate:deploy": "node scripts/prisma-safe.cjs migrate deploy",
    "prisma:seed": "node scripts/prisma-safe.cjs db seed",
    "prisma:seed:prod": "ALLOW_PROD_SEED=1 NODE_ENV=production node scripts/prisma-safe.cjs db seed"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=20.18.0 <23"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "clsx": "^2.1.1",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-auth": "^4.24.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.182.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
