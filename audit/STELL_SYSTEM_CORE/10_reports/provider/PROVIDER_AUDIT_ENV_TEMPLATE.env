# Provider API live audit credential template (no real secrets in this file)
# Recommended secure location:
#   /root/workspace/.secrets/provider_audit.env  (chmod 600)
# Alternative runtime env files (fallback):
#   - /root/workspace/.env
#   - /root/stell/.env
#   - /root/stell/webhook/.env
#
# Cloudflare (required for live DNS/Workers API audit)
CLOUDFLARE_API_TOKEN=
# Optional alias:
# CF_API_TOKEN=

# Strongly recommended for deterministic account selection
CLOUDFLARE_ACCOUNT_ID=
# Optional alias:
# CF_ACCOUNT_ID=

# Vercel (required for projects/deployments/env live audit)
VERCEL_TOKEN=

# Optional but recommended for deterministic team/project scoping
VERCEL_TEAM_ID=
# Optional alias:
# VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
