FROM python:3.11-slim

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    curl ca-certificates xz-utils procps netcat-openbsd assimp-utils \
    g++ cmake make \
    libocct-data-exchange-7.8 libocct-modeling-data-7.8 libocct-modeling-algorithms-7.8 \
    libocct-foundation-7.8 libocct-ocaf-7.8 libocct-visualization-7.8 occt-misc \
    libocct-data-exchange-dev libocct-modeling-data-dev libocct-modeling-algorithms-dev \
    libocct-foundation-dev libocct-ocaf-dev libocct-visualization-dev libocct-draw-dev \
    libfontconfig1-dev libtbb-dev libfuse2 \
    libgl1 libx11-6 libxi6 libxrender1 libxrandr2 libxkbcommon0 libxxf86vm1 libsm6 libice6 \
  && rm -rf /var/lib/apt/lists/*

COPY tools/occt-convert /tmp/occt-convert
RUN cmake -S /tmp/occt-convert -B /tmp/occt-convert/build -DCMAKE_BUILD_TYPE=Release \
  && cmake --build /tmp/occt-convert/build --config Release \
  && cp /tmp/occt-convert/build/occt-convert /usr/local/bin/occt-convert \
  && rm -rf /tmp/occt-convert

ENV BLENDER_VERSION=4.5.6
ENV BLENDER_URL=https://ftp.nluug.nl/pub/graphics/blender/release/Blender4.5/blender-4.5.6-linux-x64.tar.xz
ENV BLENDER_SHA256_URL=https://ftp.nluug.nl/pub/graphics/blender/release/Blender4.5/blender-4.5.6.sha256
RUN mkdir -p /opt/blender/4.5.6 \
  && curl -L "$BLENDER_URL" -o /tmp/blender.tar.xz \
  && curl -L "$BLENDER_SHA256_URL" -o /tmp/blender.sha256 \
  && (grep "blender-4.5.6-linux-x64.tar.xz" /tmp/blender.sha256 | sha256sum -c - || true) \
  && tar -xf /tmp/blender.tar.xz -C /opt/blender/4.5.6 --strip-components=1 \
  && ln -sf /opt/blender/4.5.6/blender /usr/local/bin/blender \
  && rm -f /tmp/blender.tar.xz /tmp/blender.sha256

ENV FREECAD_VERSION=1.0.2
ENV FREECAD_URL=https://github.com/FreeCAD/FreeCAD/releases/download/1.0.2/FreeCAD_1.0.2-conda-Linux-x86_64-py311.AppImage
RUN mkdir -p /opt/freecad/1.0.2 \
  && curl -L "$FREECAD_URL" -o /opt/freecad/1.0.2/FreeCAD.AppImage \
  && chmod +x /opt/freecad/1.0.2/FreeCAD.AppImage \
  && ln -sf /opt/freecad/1.0.2/FreeCAD.AppImage /usr/local/bin/freecad

COPY requirements.txt /app/requirements.txt
RUN python3 -m pip install --no-cache-dir -r /app/requirements.txt

COPY app /app/app

# Wait for Redis before starting the worker process.
CMD ["sh", "-lc", "\
  echo 'Waiting for redis:6379...' && until nc -z redis 6379; do sleep 1; done; \
  echo 'Starting RQ worker...' && \
  python -m app.workers.worker_main \
"]
