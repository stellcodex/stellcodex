# Required base backend settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellcodex
JWT_SECRET=replace-with-32-plus-char-secret

# Optional: enables runtime event mirror onto Redis stream via existing EventBus
REDIS_URL=redis://127.0.0.1:6379/0

# Optional: use this when running STELL-AI smoke tools from backend root
PYTHONPATH=.
