{
  "id": "APP_003",
  "slug": "stellmesh",
  "name": "StellMesh",
  "version": "7.0.0",
  "category": "geometry",
  "tier": "free",
  "enabled_by_default": true,
  "description": "Mesh geometry processing for STL, OBJ, and PLY formats",
  "entry_point": "/apps/stellmesh",
  "routes": [
    "/apps/stellmesh"
  ],
  "required_capabilities": [
    "mesh"
  ],
  "supported_formats": [
    "stl",
    "obj",
    "ply"
  ],
  "permissions": {
    "required_role": "any",
    "requires_auth": true,
    "allow_guest": true
  },
  "api_endpoints": [
    "/api/v1/files/{file_id}/gltf",
    "/api/v1/files/{file_id}/lod/{lod_name}"
  ],
  "feature_flags": {
    "enabled": true,
    "env_override": "APP_STELLMESH"
  },
  "dependencies": {
    "backend": true,
    "redis": false,
    "minio": false,
    "worker": true
  },
  "schema_version": "stellcodex.v7.app_manifest.1.0"
}