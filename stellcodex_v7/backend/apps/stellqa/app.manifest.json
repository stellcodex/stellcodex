{
  "id": "APP_016",
  "slug": "stellqa",
  "name": "StellQA",
  "version": "7.0.0",
  "category": "quality",
  "tier": "free",
  "enabled_by_default": true,
  "description": "Quality assurance checklist and report tool",
  "entry_point": "/apps/stellqa",
  "routes": [
    "/apps/stellqa"
  ],
  "required_capabilities": [
    "qa"
  ],
  "supported_formats": [
    "json"
  ],
  "permissions": {
    "required_role": "any",
    "requires_auth": true,
    "allow_guest": true
  },
  "api_endpoints": [
    "/api/v1/files/{file_id}/decision_json",
    "/api/v1/orchestrator/session"
  ],
  "feature_flags": {
    "enabled": true,
    "env_override": "APP_STELLQA"
  },
  "dependencies": {
    "backend": true,
    "redis": false,
    "minio": false,
    "worker": false
  },
  "schema_version": "stellcodex.v7.app_manifest.1.0"
}