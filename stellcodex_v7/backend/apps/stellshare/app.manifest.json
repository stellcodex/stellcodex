{
  "id": "APP_006",
  "slug": "stellshare",
  "name": "StellShare",
  "version": "7.0.0",
  "category": "collaboration",
  "tier": "free",
  "enabled_by_default": true,
  "description": "Secure file and model sharing with link generation",
  "entry_point": "/apps/stellshare",
  "routes": [
    "/apps/stellshare"
  ],
  "required_capabilities": [
    "share"
  ],
  "supported_formats": [
    "link"
  ],
  "permissions": {
    "required_role": "any",
    "requires_auth": true,
    "allow_guest": true
  },
  "api_endpoints": [
    "/api/v1/files/{file_id}/share",
    "/api/v1/share/resolve"
  ],
  "feature_flags": {
    "enabled": true,
    "env_override": "APP_STELLSHARE"
  },
  "dependencies": {
    "backend": true,
    "redis": false,
    "minio": false,
    "worker": false
  },
  "schema_version": "stellcodex.v7.app_manifest.1.0"
}