{
  "id": "APP_024",
  "slug": "stellreport",
  "name": "StellReport",
  "version": "7.0.0",
  "category": "reporting",
  "tier": "free",
  "enabled_by_default": true,
  "description": "Manufacturing report builder for MD/JSON/PDF",
  "entry_point": "/apps/stellreport",
  "routes": [
    "/apps/stellreport"
  ],
  "required_capabilities": [
    "report"
  ],
  "supported_formats": [
    "md",
    "json",
    "pdf"
  ],
  "permissions": {
    "required_role": "any",
    "requires_auth": true,
    "allow_guest": true
  },
  "api_endpoints": [
    "/api/v1/files/{file_id}/decision_json",
    "/api/v1/quotes/{quote_id}"
  ],
  "feature_flags": {
    "enabled": true,
    "env_override": "APP_STELLREPORT"
  },
  "dependencies": {
    "backend": true,
    "redis": false,
    "minio": false,
    "worker": false
  },
  "schema_version": "stellcodex.v7.app_manifest.1.0"
}