{
  "id": "APP_008",
  "slug": "stellviewer2d",
  "name": "StellViewer2D",
  "version": "7.0.0",
  "category": "viewer",
  "tier": "free",
  "enabled_by_default": true,
  "description": "2D drawing viewer for DXF, PDF, and SVG files",
  "entry_point": "/apps/stellviewer2d",
  "routes": [
    "/apps/stellviewer2d"
  ],
  "required_capabilities": [
    "viewer2d"
  ],
  "supported_formats": [
    "dxf",
    "pdf",
    "svg"
  ],
  "permissions": {
    "required_role": "any",
    "requires_auth": true,
    "allow_guest": true
  },
  "api_endpoints": [
    "/api/v1/files/{file_id}/gltf",
    "/api/v1/files/{file_id}/manifest"
  ],
  "feature_flags": {
    "enabled": true,
    "env_override": "APP_STELLVIEWER2D"
  },
  "dependencies": {
    "backend": true,
    "redis": false,
    "minio": false,
    "worker": false
  },
  "schema_version": "stellcodex.v7.app_manifest.1.0"
}