    "vision"
  ],
  "supported_formats": [
    "png",
    "jpg",
    "tif"
  ],
  "permissions": {
    "required_role": "user",
    "requires_auth": true,
    "allow_guest": false
  },
  "api_endpoints": [
    "/api/v1/stell/chat",
    "/api/v1/stell/context"
  ],
  "feature_flags": {
    "enabled": false,
    "env_override": "APP_STELLVISION"
  },
  "dependencies": {
    "backend": true,
    "redis": false,
    "minio": false,
    "worker": false
  },
  "schema_version": "stellcodex.v7.app_manifest.1.0"
}