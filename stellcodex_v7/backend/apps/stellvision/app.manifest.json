{
  "id": "APP_038",
  "slug": "stellvision",
  "name": "StellVision",
  "version": "7.0.0",
  "category": "ai",
  "tier": "paid",
  "enabled_by_default": false,
  "description": "Computer vision quality inspection from images (paid)",
  "entry_point": "/apps/stellvision",
  "routes": [
