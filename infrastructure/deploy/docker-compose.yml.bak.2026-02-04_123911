version: "3.3"

services:
  backend:
    build:
      context: ../backend
    container_name: stellcodex-backend
    env_file:
      - .env
    ports:
      - "8000:8000"
    depends_on:
      - postgres
      - redis
      - rabbitmq
      - minio
    restart: unless-stopped

  worker:
    build:
      context: ../backend
    container_name: stellcodex-worker
    env_file:
      - .env
    environment:
      - PYTHONPATH=/app
    command: ["celery", "-A", "app.workers.celery_app.celery", "worker", "--loglevel=INFO"]
    depends_on:
      - redis
      - rabbitmq
    restart: unless-stopped

  postgres:
    image: postgres:15
    container_name: stellcodex-postgres
    environment:
      POSTGRES_DB: stellcodex
      POSTGRES_USER: stellcodex
      POSTGRES_PASSWORD: stellcodex
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U stellcodex -d stellcodex"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  redis:
    image: redis:7
    container_name: stellcodex-redis
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 3s
      retries: 5
    restart: unless-stopped

  rabbitmq:
    image: rabbitmq:3-management
    container_name: stellcodex-rabbitmq
    ports:
      - "5672:5672"
      - "15672:15672"
    healthcheck:
      test: ["CMD-SHELL", "rabbitmq-diagnostics -q ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  minio:
    image: minio/minio:RELEASE.2022-10-24T18-35-07Z
    container_name: stellcodex-minio
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: stellcodex
      MINIO_ROOT_PASSWORD: stellcodex123
      MINIO_SERVER_URL: "http://127.0.0.1:9000"
      MINIO_BROWSER_REDIRECT_URL: "http://127.0.0.1:9001"
    ports:
      - "9000:9000"
      - "9001:9001"
    volumes:
      - minio_data:/data
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://127.0.0.1:9000/minio/health/ready"]
      interval: 10s
      timeout: 5s
      retries: 10
    restart: unless-stopped

volumes:
  postgres_data:
  minio_data:
