OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
ABACUSAI_API_KEY=
# Alias also supported by auto-discovery: ABACUS_API_KEY

# Optional local:
ENABLE_OLLAMA=0
OLLAMA_BASE_URL=http://ollama:11434
# Optional override for older Docker/Compose environments:
OLLAMA_IMAGE=ollama/ollama:latest

# Orchestrator:
LLM_BASE_URL=http://litellm:4000/v1
LLM_API_KEY=dummy
HTTP_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=700
LOCAL_MAX_TOKENS=120
PAID_CALL_TIMEOUT_SECONDS=45
LOCAL_CALL_TIMEOUT_SECONDS=20
SCHEDULER_INTERVAL_SECONDS=60

# Autopilot:
AUTOPILOT_LOOP_SECONDS=5
AUTOPILOT_MAX_RETRIES=5
AUTOPILOT_DEFER_RETRY_SECONDS=900
AUTOPILOT_SCAN_INTERVAL_SECONDS=600
DAILY_REPORT_HOUR=9
TZ=Europe/Istanbul

# Optional WhatsApp:
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TO=
