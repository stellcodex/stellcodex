FROM python:3.11.9-slim

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    curl procps netcat-openbsd assimp-utils \
    g++ cmake make \
    libocct-data-exchange-7.8 libocct-modeling-data-7.8 libocct-modeling-algorithms-7.8 \
    libocct-foundation-7.8 libocct-ocaf-7.8 libocct-visualization-7.8 occt-misc \
    libocct-data-exchange-dev libocct-modeling-data-dev libocct-modeling-algorithms-dev \
    libocct-foundation-dev libocct-ocaf-dev libocct-visualization-dev libocct-draw-dev \
    libfontconfig1-dev libtbb-dev \
  && rm -rf /var/lib/apt/lists/*

COPY tools/occt-convert /tmp/occt-convert
RUN cmake -S /tmp/occt-convert -B /tmp/occt-convert/build -DCMAKE_BUILD_TYPE=Release \
  && cmake --build /tmp/occt-convert/build --config Release \
  && cp /tmp/occt-convert/build/occt-convert /usr/local/bin/occt-convert \
  && rm -rf /tmp/occt-convert

COPY requirements.txt /app/requirements.txt
RUN python3 -m pip install --no-cache-dir -r /app/requirements.txt

COPY alembic.ini .
COPY alembic ./alembic
COPY app /app/app

# DB/Redis/MinIO startup waits are configurable to avoid hardcoded DNS coupling.
CMD ["sh", "-lc", "\
  DB_HOST=${DB_HOST:-stellcodex-postgres}; DB_PORT=${DB_PORT:-5432}; \
  MINIO_HOST=${MINIO_HOST:-stellcodex-minio}; MINIO_PORT=${MINIO_PORT:-9000}; \
  REDIS_HOST=${REDIS_HOST:-stellcodex-redis}; REDIS_PORT=${REDIS_PORT:-6379}; \
  echo \"Waiting for ${DB_HOST}:${DB_PORT}...\" && until nc -z ${DB_HOST} ${DB_PORT}; do sleep 1; done; \
  echo \"Waiting for ${MINIO_HOST}:${MINIO_PORT}...\" && until nc -z ${MINIO_HOST} ${MINIO_PORT}; do sleep 1; done; \
  echo \"Waiting for ${REDIS_HOST}:${REDIS_PORT}...\" && until nc -z ${REDIS_HOST} ${REDIS_PORT}; do sleep 1; done; \
  echo 'Starting backend...' && \
  uvicorn app.main:app --host 0.0.0.0 --port 8000 \
"]
