+@router.post("/initiate", response_model=CreateUploadOut)
+def initiate_upload(
+    data: CreateUploadIn,
+    db: Session = Depends(get_db),
+    user: dict = Depends(_require_user),
+):
+    _feature_on()
+    if not data.filename:
+        raise HTTPException(status_code=400, detail="filename required")
+    _validate_upload(data.content_type, data.size_bytes)
+
+    owner_sub = str(user.get("sub") or "anonymous")
+    key = _safe_object_key(owner_sub)
+    bucket = settings.s3_bucket
+
+    # DB record: pending
+    f = File(
+        owner_sub=owner_sub,
+        bucket=bucket,
+        object_key=key,
+        original_filename=data.filename,
+        content_type=data.content_type,
+        size_bytes=data.size_bytes,
+        sha256=data.sha256,
+        status="pending",
+        visibility="private",
+        created_at=_now(),
+        updated_at=_now(),
+    )
+    db.add(f)
+    db.commit()
+    db.refresh(f)
+
+    s3 = s3_client()
+    url = s3.generate_presigned_url(
+        "put_object",
+        Params={"Bucket": bucket, "Key": key, "ContentType": data.content_type},
+        ExpiresIn=900,
+    )
+    return CreateUploadOut(file_id=f.file_id, object_key=key, upload_url=url, expires_in_seconds=900)
