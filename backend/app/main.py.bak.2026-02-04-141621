from app.core.minio_bootstrap import ensure_bucket_exists

from fastapi import FastAPI
from app.api.v1.router import api_router

app = FastAPI(title="STELLCODEX API")

app.include_router(api_router, prefix="/api/v1")

@app.get("/")
def root():
    return {"service": "stellcodex-backend", "docs": "/docs", "health": "/api/v1/health"}

@app.on_event("startup")
def _bootstrap_minio_bucket():
    import logging; logging.getLogger("uvicorn.error").info("BOOTSTRAP: calling ensure_bucket_exists()")
    # MinIO bucket otomatik oluşturma / doğrulama
    ensure_bucket_exists()
