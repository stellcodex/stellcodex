from typing import Optional
from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    def model_post_init(self, __context):
        # Prefer STELLCODEX_S3_*; keep S3_* for backward compatibility
        if getattr(self, "STELLCODEX_S3_ENDPOINT", None) and not getattr(self, "S3_ENDPOINT", None):
            self.S3_ENDPOINT = self.STELLCODEX_S3_ENDPOINT
        if getattr(self, "STELLCODEX_S3_ACCESS_KEY", None) and not getattr(self, "S3_ACCESS_KEY", None):
            self.S3_ACCESS_KEY = self.STELLCODEX_S3_ACCESS_KEY
        if getattr(self, "STELLCODEX_S3_SECRET_KEY", None) and not getattr(self, "S3_SECRET_KEY", None):
            self.S3_SECRET_KEY = self.STELLCODEX_S3_SECRET_KEY
        if getattr(self, "STELLCODEX_S3_BUCKET", None) and not getattr(self, "S3_BUCKET", None):
            self.S3_BUCKET = self.STELLCODEX_S3_BUCKET
    model_config = SettingsConfigDict(env_file=".env", extra="ignore")

    APP_NAME: str = "stellcodex"
    ENV: str = "dev"

    DATABASE_URL: str
    REDIS_URL: str
    RABBITMQ_URL: str
    S3_ENDPOINT: Optional[str]
    S3_ACCESS_KEY: Optional[str]
    S3_SECRET_KEY: Optional[str]
    S3_BUCKET: Optional[str]
    S3_SECURE: bool = False

    JWT_SECRET: str
    JWT_ALG: str = "HS256"
    ACCESS_TOKEN_MINUTES: int = 30
    REFRESH_TOKEN_DAYS: int = 30


settings = Settings()
