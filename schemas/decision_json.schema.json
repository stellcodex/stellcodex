{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "rule_version",
    "mode",
    "confidence",
    "manufacturing_method",
    "rule_explanations",
    "conflict_flags"
  ],
  "properties": {
    "rule_version": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "brep",
        "mesh_approx",
        "visual_only"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "manufacturing_method": {
      "type": "string"
    },
    "rule_explanations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "triggered",
          "severity",
          "reference",
          "reasoning"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "triggered": {
            "type": "boolean"
          },
          "severity": {
            "type": "string",
            "enum": [
              "INFO",
              "LOW",
              "MEDIUM",
              "HIGH"
            ]
          },
          "reference": {
            "type": "string"
          },
          "reasoning": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "conflict_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}